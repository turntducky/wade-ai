{
  "productName": "W.A.D.E.",
  "version": "0.1.0",
  "identifier": "com.turntducky.wade",
  "build": {
    "frontendDist": "http://localhost:8000/ui",
    "devUrl":       "http://localhost:8000/ui",
    "beforeDevCommand":   "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label":     "main",
        "title":     "W.A.D.E.",
        "width":     1200,
        "height":    800,
        "visible":   false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8000"
    }
  },
  "bundle": {
    "active": false,
    "icon":   ["icons/tray-idle-32.png"],
    "externalBin": [
      "binaries/wade_server"
    ]
  }
}
